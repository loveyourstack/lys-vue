{
  "name": "lys-vue",
  "version": "0.1.8",
  "description": "Vue + Vuetify component library for LoveYourStack projects",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/lys-vue.js",
  "module": "./dist/lys-vue.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lys-vue.js",
      "types": "./dist/main.d.ts"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "vue-tsc -b ./tsconfig-build.json --noEmit && vite build",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "axios": "^1.13.0",
    "vue": "^3.5.0",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/language-core": "^3.2.8",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.16.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "unplugin-dts": "^1.0.0",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.6",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7",
    "vuetify": "^4.0.6"
  }
}
